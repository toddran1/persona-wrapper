{
  "name": "persona-wrapper-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:test": "node scripts/dev.mjs --test-mode",
    "dev:test-mode": "node scripts/dev.mjs --test-mode",
    "dev:api": "npm run dev -w @persona/api",
    "dev:mobile": "npm run dev -w @persona/mobile",
    "dev:web": "npm run dev -w @persona/web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "npm run db:migrate -w @persona/api",
    "test:e2e": "node scripts/e2e.mjs",
    "test:e2e:web": "node scripts/e2e.mjs",
    "test:e2e:mobile": "maestro test e2e/mobile",
    "build": "npm run build -w @persona/shared && npm run build -w @persona/api && npm run build -w @persona/web && npm run build -w @persona/mobile",
    "typecheck": "npm run build -w @persona/shared && npm run typecheck -w @persona/api && npm run typecheck -w @persona/web && npm run typecheck -w @persona/mobile",
    "lint": "biome lint .",
    "test": "npm run build -w @persona/shared && npm run test -w @persona/api && npm run test -w @persona/web",
    "check": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": "^22.13.0 || >=24.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@playwright/test": "^1.57.0",
    "@types/react": "19.2.4",
    "concurrently": "^9.1.2"
  },
  "overrides": {
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-screens": "4.25.2",
    "expo-router": "57.0.6",
    "expo-constants": "57.0.5"
  },
  "dependencies": {
    "expo": "~57.0.6",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "packageManager": "npm@11.16.0"
}
