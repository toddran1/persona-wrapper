{
  "name": "@persona/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint app src app.config.ts",
    "audit:accessibility": "node scripts/audit-accessibility.mjs",
    "verify:release": "npm run typecheck && npm run audit:accessibility",
    "build": "npm run verify:release",
    "eas-build-post-install": "cd ../.. && npm run build -w @persona/shared"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@persona/shared": "*",
    "@react-native-community/netinfo": "^12.0.1",
    "@shopify/flash-list": "^2.0.2",
    "@tanstack/react-query": "^5.101.2",
    "@ts-rest/core": "^3.52.1",
    "expo": "~57.0.6",
    "expo-audio": "~57.0.2",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.5",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-image-picker": "~57.0.4",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-localization": "~57.0.1",
    "expo-media-library": "~57.0.2",
    "expo-router": "~57.0.6",
    "expo-secure-store": "~57.0.1",
    "expo-sharing": "~57.0.5",
    "expo-speech-recognition": "~56.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-video": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "jszip": "^3.10.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-enriched-markdown": "^0.7.4",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.4",
    "typescript": "~6.0.3"
  }
}
