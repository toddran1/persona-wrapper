{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:4000"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://for-the-baddiez-api-dev.onrender.com",
        "EXPO_PUBLIC_WEB_APP_URL": "https://for-the-baddiez-web-dev.onrender.com",
        "EXPO_PUBLIC_ANDROID_APP_LINK_HOST": "for-the-baddiez-web-dev.onrender.com"
      }
    },
    "testflight": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://for-the-baddiez-api-dev.onrender.com",
        "EXPO_PUBLIC_WEB_APP_URL": "https://for-the-baddiez-web-dev.onrender.com",
        "EXPO_PUBLIC_ANDROID_APP_LINK_HOST": "for-the-baddiez-web-dev.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
