# Local simulator default. On a physical phone, use your computer's LAN IP,
# for example http://192.168.1.20:4000.
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_WEB_APP_URL=http://localhost:5173

# Preview/prod EAS builds should set this to the deployed API URL.
# EXPO_PUBLIC_API_URL=https://api.example.com
# EXPO_PUBLIC_WEB_APP_URL=https://www.forthebaddiez.com
