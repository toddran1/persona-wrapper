{
  "name": "@persona/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/scripts/migrateDatabase.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "accounts:purge-deleted": "tsx src/scripts/purgeDeletedAccounts.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint src drizzle.config.ts",
    "test": "NODE_ENV=test DATABASE_URL= AUTH_REQUIRED=false AUTH_REQUIRE_OWNED_MEDIA_ACCESS=false OBSERVABILITY_DASHBOARD_TOKEN= OTEL_EXPORTER_OTLP_ENDPOINT= OTEL_EXPORTER_OTLP_HEADERS= STYLE_TRANSFER_PROVIDER=stub vitest run",
    "test:integration:openai": "DATABASE_URL= OPENAI_RUN_INTEGRATION_TESTS=true STYLE_TRANSFER_PROVIDER=stub vitest run src/test/openai.integration.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/lib-storage": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@better-auth/expo": "^1.6.23",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@persona/shared": "*",
    "@ts-rest/core": "^3.53.0-rc.1",
    "@ts-rest/express": "^3.53.0-rc.1",
    "archiver": "^7.0.1",
    "better-auth": "^1.6.23",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.1",
    "file-type": "^22.0.1",
    "jszip": "^3.10.1",
    "multer": "^2.2.0",
    "openai": "^6.42.0",
    "pg-boss": "^12.26.1",
    "postgres": "^3.4.9",
    "unzipper": "^0.12.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.8.1",
    "@types/unzipper": "^0.10.11",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.1",
    "typescript": "~6.0.3",
    "vitest": "^3.2.7"
  }
}
