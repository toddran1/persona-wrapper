PORT=4000
NODE_ENV=development
OPENAI_API_KEY=
OPENAI_RUN_INTEGRATION_TESTS=false
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REQUEST_TIMEOUT_MS=120000
OPENAI_MAX_RETRIES=3
OPENAI_MAX_TOOL_ITERATIONS=4
OPENAI_MAX_CONTEXT_MESSAGES=24
OPENAI_MAX_CONTEXT_CHARACTERS=60000
OPENAI_ENABLE_WEB_SEARCH=true
OPENAI_ENABLE_FILE_SEARCH=true
OPENAI_ENABLE_CODE_INTERPRETER=true
OPENAI_ENABLE_IMAGE_GENERATION=true
# Optional current pricing inputs used only for estimated-cost metadata.
OPENAI_INPUT_COST_PER_MILLION=0
OPENAI_OUTPUT_COST_PER_MILLION=0
OPENAI_DAILY_SPEND_LIMIT_USD=5
OPENAI_DAILY_TOKEN_LIMIT=1000000
CHAT_RATE_LIMIT_REQUESTS=30
CHAT_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_DIR=apps/api/uploads
UPLOAD_MAX_BYTES=26214400
UPLOAD_TTL_HOURS=24
ANTHROPIC_API_KEY=
LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434
LOCAL_LLM_MODEL=llama3.2:3b
OPENAI_TTS_VOICE=alloy
STYLE_TRANSFER_PROVIDER=stub
STYLE_TRANSFER_ENDPOINT=
STYLE_TRANSFER_MODEL_ID=
