PORT=4000
NODE_ENV=development
API_REQUEST_TIMEOUT_MS=120000
API_HEADERS_TIMEOUT_MS=60000
API_KEEP_ALIVE_TIMEOUT_MS=5000
API_SHUTDOWN_TIMEOUT_MS=10000
APP_TEST_MODE=false
# Comma-separated browser origins allowed to call the API in production.
# Leave blank in local development to allow same-machine testing.
CORS_ALLOWED_ORIGINS=
OPENAI_API_KEY=
OPENAI_RUN_INTEGRATION_TESTS=false
OPENAI_MODEL=gpt-5.6-luna
OPENAI_REQUEST_TIMEOUT_MS=120000
OPENAI_MAX_OUTPUT_TOKENS=8192
# Optional global OpenAI generation controls. Leave blank to use model defaults.
OPENAI_TEMPERATURE=
OPENAI_TOP_P=
OPENAI_PRESENCE_PENALTY=
OPENAI_FREQUENCY_PENALTY=
OPENAI_REASONING_EFFORT=
OPENAI_REASONING_SUMMARY=
OPENAI_TEXT_VERBOSITY=
# Direct persona path defaults. top_p is optional; if set, it overrides persona temperature.
OPENAI_PERSONA_TEMPERATURE=
OPENAI_PERSONA_TOP_P=
OPENAI_PERSONA_PRESENCE_PENALTY=
OPENAI_PERSONA_FREQUENCY_PENALTY=
OPENAI_PERSONA_REASONING_EFFORT=high
OPENAI_PERSONA_REASONING_SUMMARY=
OPENAI_PERSONA_TEXT_VERBOSITY=high
OPENAI_MAX_RETRIES=3
OPENAI_IMAGE_REQUEST_TIMEOUT_MS=300000
OPENAI_BACKGROUND_POLL_TIMEOUT_MS=600000
OPENAI_BACKGROUND_POLL_INTERVAL_MS=1500
OPENAI_MAX_TOOL_ITERATIONS=4
OPENAI_MAX_CONTEXT_MESSAGES=16
OPENAI_MAX_CONTEXT_CHARACTERS=35000
OPENAI_MAX_CONTEXT_TOKENS=8000
CONVERSATION_MEMORY_SUMMARY_ENABLED=true
CONVERSATION_MEMORY_SUMMARY_AFTER_MESSAGES=16
CONVERSATION_MEMORY_SUMMARY_MAX_CHARACTERS=2500
CONVERSATION_MEMORY_SUMMARY_MAX_TOKENS=800
OPENAI_STYLE_REFERENCE_SYNTHETIC_LIMIT=20
OPENAI_STYLE_REFERENCE_GOLDEN_LIMIT=5
OPENAI_STYLE_REFERENCE_MAX_TOKENS=9000
OPENAI_TOOL_ROUTER_ENABLED=true
OPENAI_TOOL_ROUTER_MODEL=gpt-5.4-nano
OPENAI_ENABLE_WEB_SEARCH=true
OPENAI_ENABLE_FILE_SEARCH=true
OPENAI_ENABLE_CODE_INTERPRETER=true
OPENAI_ENABLE_IMAGE_GENERATION=true
OPENAI_DIRECT_IMAGE_API_ENABLED=true
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_MODERATION=low
OPENAI_IMAGE_SIZE=auto
OPENAI_IMAGE_QUALITY=auto
OPENAI_TTS_SCRIPT_ENABLED=false
# Optional current pricing inputs used only for estimated-cost metadata.
OPENAI_INPUT_COST_PER_MILLION=0
OPENAI_OUTPUT_COST_PER_MILLION=0
OPENAI_DAILY_SPEND_LIMIT_USD=5
OPENAI_DAILY_TOKEN_LIMIT=1000000
CHAT_RATE_LIMIT_REQUESTS=30
CHAT_RATE_LIMIT_WINDOW_MS=60000
DATABASE_URL=postgres://persona:persona_dev_password@localhost:5434/persona_wrapper_db
STORAGE_DRIVER=local
# One local root for uploaded files, generated images/files, and generated audio.
# Leave blank to use UPLOAD_DIR plus the legacy generated-media/generated-audio subfolders.
STORAGE_LOCAL_ROOT=/Volumes/ReggieSSD/mac/coding-projects/python/persona_wrapper/media
# Production only. Set STORAGE_DRIVER=s3 with NODE_ENV=production to store object bytes in S3.
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
# Optional prefix for separating environments in one bucket, for example prod/persona-wrapper.
STORAGE_S3_PREFIX=
# Optional endpoint/path-style settings for S3-compatible storage. Leave blank/false for AWS S3.
STORAGE_S3_ENDPOINT=
STORAGE_S3_FORCE_PATH_STYLE=false
UPLOAD_DIR=apps/api/uploads
# Legacy upload path used when STORAGE_LOCAL_ROOT is blank.
# Generated provider media is persisted outside conversation JSON. Leave blank to use UPLOAD_DIR/generated-media.
GENERATED_MEDIA_DIR=
# Legacy generated media path used when STORAGE_LOCAL_ROOT is blank.
# 0 keeps generated conversation media until it is manually deleted.
GENERATED_MEDIA_TTL_HOURS=0
# 0 keeps OpenAI artifact files until they are manually deleted.
OPENAI_ARTIFACT_TTL_HOURS=0
# Generated TTS audio can be stored separately from temporary uploads. Leave blank to use UPLOAD_DIR/generated-audio.
GENERATED_AUDIO_DIR=
# Legacy generated audio path used when STORAGE_LOCAL_ROOT is blank.
# 236 keeps generated response audio for a little under 10 days.
GENERATED_AUDIO_TTL_HOURS=236
UPLOAD_MAX_BYTES=26214400
# 24 keeps uploaded assets for one day.
UPLOAD_TTL_HOURS=24
# Runs upload/generated-media/generated-audio expiration cleanup every 15 minutes. Set 0 to disable.
STORAGE_CLEANUP_INTERVAL_MS=900000
ANTHROPIC_API_KEY=
LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434
LOCAL_LLM_MODEL=llama3.2:3b
LOCAL_LLM_NUM_CTX=8192
LOCAL_LLM_NUM_PREDICT=1024
TTS_PROVIDER=openai
OPENAI_TTS_VOICE=alloy
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_ID_LARAE=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_SPEED=1.06
ELEVENLABS_STABILITY=0.30
ELEVENLABS_SIMILARITY_BOOST=0.60
ELEVENLABS_STYLE=0.10
ELEVENLABS_USE_SPEAKER_BOOST=true
ELEVENLABS_MAX_RETRIES=2
ELEVENLABS_RETRY_BASE_MS=400
STYLE_TRANSFER_PROVIDER=stub
STYLE_TRANSFER_ENDPOINT=
STYLE_TRANSFER_MODEL_ID=

# Optional OAuth credentials for social login. Leave blank to disable.
AUTH_REQUIRED=false
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_PASSWORD_MIN_LENGTH=10
AUTH_ACCOUNT_DELETION_GRACE_DAYS=30
AUTH_REQUIRE_OWNED_MEDIA_ACCESS=false
AUTH_RATE_LIMIT_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_MS=900000
API_JSON_MAX_BYTES=1048576
DATA_TRANSFER_MAX_BYTES=26214400
WEB_APP_URL=http://localhost:5173
IOS_OAUTH_REDIRECT_URL=personawrapper://auth/callback
ANDROID_OAUTH_REDIRECT_URL=personawrapper://auth/callback
OAUTH_REDIRECT_BASE_URL=http://localhost:4000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
